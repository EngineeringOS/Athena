{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "athena",
  "word": "identifier",
  "rules": {
    "source_file": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "package_declaration"
                },
                {
                  "type": "SYMBOL",
                  "name": "incomplete_package_declaration"
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "import_declaration"
              },
              {
                "type": "SYMBOL",
                "name": "incomplete_import_declaration"
              }
            ]
          }
        },
        {
          "type": "SYMBOL",
          "name": "system_declaration"
        }
      ]
    },
    "package_declaration": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "package"
        },
        {
          "type": "SYMBOL",
          "name": "_header_space"
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "package_name"
          }
        }
      ]
    },
    "import_declaration": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "import"
        },
        {
          "type": "SYMBOL",
          "name": "_header_space"
        },
        {
          "type": "FIELD",
          "name": "target",
          "content": {
            "type": "SYMBOL",
            "name": "package_name"
          }
        }
      ]
    },
    "incomplete_package_declaration": {
      "type": "PREC",
      "value": -1,
      "content": {
        "type": "STRING",
        "value": "package"
      }
    },
    "incomplete_import_declaration": {
      "type": "PREC",
      "value": -1,
      "content": {
        "type": "STRING",
        "value": "import"
      }
    },
    "package_name": {
      "type": "IMMEDIATE_TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "PATTERN",
            "value": "[A-Za-z_][A-Za-z0-9_]*"
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": "-"
                },
                {
                  "type": "PATTERN",
                  "value": "[A-Za-z_][A-Za-z0-9_]*"
                }
              ]
            }
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": "."
                },
                {
                  "type": "PATTERN",
                  "value": "[A-Za-z_][A-Za-z0-9_]*"
                },
                {
                  "type": "REPEAT",
                  "content": {
                    "type": "SEQ",
                    "members": [
                      {
                        "type": "STRING",
                        "value": "-"
                      },
                      {
                        "type": "PATTERN",
                        "value": "[A-Za-z_][A-Za-z0-9_]*"
                      }
                    ]
                  }
                }
              ]
            }
          }
        ]
      }
    },
    "_header_space": {
      "type": "IMMEDIATE_TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[ \\t]+"
      }
    },
    "system_declaration": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "system"
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "ALIAS",
            "content": {
              "type": "SYMBOL",
              "name": "identifier"
            },
            "named": true,
            "value": "name"
          }
        },
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "declaration"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": "}"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "declaration": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "device_declaration"
        },
        {
          "type": "SYMBOL",
          "name": "port_declaration"
        },
        {
          "type": "SYMBOL",
          "name": "connect_declaration"
        }
      ]
    },
    "device_declaration": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "device"
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "ALIAS",
            "content": {
              "type": "SYMBOL",
              "name": "identifier"
            },
            "named": true,
            "value": "name"
          }
        },
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "property_assignment"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": "}"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "port_declaration": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "port"
        },
        {
          "type": "SYMBOL",
          "name": "qualified_name"
        },
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "property_assignment"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": "}"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "connect_declaration": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "connect"
        },
        {
          "type": "FIELD",
          "name": "from",
          "content": {
            "type": "SYMBOL",
            "name": "qualified_name"
          }
        },
        {
          "type": "STRING",
          "value": "->"
        },
        {
          "type": "FIELD",
          "name": "to",
          "content": {
            "type": "SYMBOL",
            "name": "qualified_name"
          }
        }
      ]
    },
    "qualified_name": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": "."
              },
              {
                "type": "SYMBOL",
                "name": "identifier"
              }
            ]
          }
        }
      ]
    },
    "property_assignment": {
      "type": "SEQ",
      "members": [
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          },
          "named": true,
          "value": "property_name"
        },
        {
          "type": "SYMBOL",
          "name": "_scalar_value"
        }
      ]
    },
    "_scalar_value": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "SYMBOL",
          "name": "string"
        }
      ]
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[A-Za-z_][A-Za-z0-9_]*"
    },
    "string": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "\""
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "string_content"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "\""
        }
      ]
    },
    "string_content": {
      "type": "PATTERN",
      "value": "[^\"]+"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    }
  ],
  "conflicts": [
    [
      "device_declaration"
    ],
    [
      "port_declaration"
    ]
  ],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}