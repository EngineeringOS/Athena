{
  "private": true,
  "name": "@engineeringood/athena-theia-product",
  "productName": "Athena",
  "version": "0.0.1",
  "description": "Athena desktop-first Theia product shell.",
  "main": "scripts/athena-electron-main.js",
  "license": "MIT",
  "engines": {
    "yarn": ">=1.7.0 <2",
    "node": ">=22"
  },
  "theia": {
    "target": "electron",
    "frontend": {
      "config": {
        "applicationName": "Athena",
        "reloadOnReconnect": true,
        "preferences": {
          "toolbar.showToolbar": true,
          "editor.enablePreview": false,
          "workbench.editor.revealIfOpen": true
        }
      }
    },
    "backend": {
      "config": {
        "frontendConnectionTimeout": -1,
        "startupTimeout": -1,
        "configurationFolder": ".athena"
      }
    }
  },
  "dependencies": {
    "@engineeringood/athena-theia-backend": "0.0.1",
    "@engineeringood/athena-theia-frontend": "0.0.1",
    "@theia/ai-chat": "1.73.1",
    "@theia/ai-chat-ui": "1.73.1",
    "@theia/ai-core": "1.73.1",
    "@theia/ai-ide": "1.73.1",
    "@theia/ai-ollama": "1.73.1",
    "@theia/ai-openai": "1.73.1",
    "@theia/core": "1.73.1",
    "@theia/editor": "1.73.1",
    "@theia/electron": "1.73.1",
    "@theia/filesystem": "1.73.1",
    "@theia/keymaps": "1.73.1",
    "@theia/markers": "1.73.1",
    "@theia/messages": "1.73.1",
    "@theia/monaco": "1.73.1",
    "@theia/navigator": "1.73.1",
    "@theia/output": "1.73.1",
    "@theia/preferences": "1.73.1",
    "@theia/process": "1.73.1",
    "@theia/terminal": "1.73.1",
    "@theia/userstorage": "1.73.1",
    "@theia/workspace": "1.73.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@theia/cli": "1.73.1",
    "electron": "39.8.7"
  },
  "scripts": {
    "clean": "theia clean && rimraf lib src-gen",
    "build": "theia build --mode development && node scripts/copy-tree-sitter-assets.js",
    "rebuild": "theia rebuild:electron",
    "start": "electron scripts/athena-electron-main.js",
    "start:m21": "electron scripts/athena-electron-open-workspace-main.js ../../examples/m21/sample-project",
    "start:m22": "electron scripts/athena-electron-open-workspace-main.js ../../examples/m22/sample-project",
    "start:m23": "electron scripts/athena-electron-open-workspace-main.js ../../examples/m23/sample-project",
    "start:m24": "electron scripts/athena-electron-open-workspace-main.js ../../examples/m24/sample-project",
    "start:m25": "electron scripts/athena-electron-open-workspace-main.js ../../examples/m25/sample-project",
    "start:m26": "electron scripts/athena-electron-open-workspace-main.js ../../examples/m26/sample-project",
    "start:m27": "electron scripts/athena-electron-open-workspace-main.js ../../examples/m27/sample-project --active-view documentation",
    "start:m28": "electron scripts/athena-electron-open-workspace-main.js ../../examples/m28/sample-project --active-view documentation",
    "start:m29": "electron scripts/athena-electron-open-workspace-main.js ../../examples/m29/sample-project --active-view documentation",
    "start:smoke": "node scripts/verify-athena-start.js",
    "start:smoke:m21": "node scripts/verify-athena-m21-sample-project.js",
    "start:smoke:m22": "node scripts/verify-athena-m22-sample-project.js",
    "start:smoke:m23": "node scripts/verify-athena-m23-sample-project.js",
    "start:smoke:m24": "node scripts/verify-athena-m24-sample-project.js",
    "start:smoke:m25": "node scripts/verify-athena-m25-sample-project.js",
    "start:smoke:m26": "node scripts/verify-athena-m26-sample-project.js",
    "start:smoke:m27": "node scripts/verify-athena-m27-sample-project.js",
    "start:smoke:m28": "node scripts/verify-athena-m28-sample-project.js",
    "start:smoke:m29": "node scripts/verify-athena-m29-sample-project.js",
    "start:smoke:tree-sitter": "node scripts/verify-athena-tree-sitter-highlighting.js",
    "start:smoke:reuse-catalog": "node scripts/verify-athena-reuse-catalog.js",
    "watch": "theia build --watch --mode development"
  }
}
